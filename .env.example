# =============================================
# UaDay Cleaning — Environment Variables
# =============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# Google Maps API Key (optional — required only for interactive maps)
# Get yours at: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Analytics 4 Measurement ID
# Get yours at: https://analytics.google.com
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Site URL (used for SEO canonical URLs and sitemap)
NEXT_PUBLIC_SITE_URL=https://uadaycleaning.com.au

# Contact form email destination (if using a form service)
# CONTACT_EMAIL=hello@uadaycleaning.com.au

# Email service API key (e.g. Resend, SendGrid)
# EMAIL_API_KEY=your_email_api_key_here
